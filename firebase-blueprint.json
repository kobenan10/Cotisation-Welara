{
  "entities": {
    "Member": {
      "title": "Member",
      "description": "A member of the association",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Full name of the member"
        },
        "payments": {
          "type": "object",
          "description": "Map of year to map of month to payment amount"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "history": {
          "type": "array",
          "description": "List of payment transactions",
          "items": { "type": "object" }
        }
      },
      "required": ["name", "payments", "createdAt"]
    },
    "Expense": {
      "title": "Expense",
      "description": "An expense of the association",
      "type": "object",
      "properties": {
        "description": {
          "type": "string",
          "description": "Description of the expense"
        },
        "amount": {
          "type": "number",
          "description": "Amount of the expense"
        },
        "month": {
          "type": "string",
          "description": "Month of the expense"
        },
        "year": {
          "type": "number",
          "description": "Year of the expense"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["description", "amount", "month", "year", "createdAt"]
    },
    "Revenue": {
      "title": "Revenue",
      "description": "An exceptional entry/revenue of the association",
      "type": "object",
      "properties": {
        "description": {
          "type": "string",
          "description": "Description of the exceptional entry"
        },
        "amount": {
          "type": "number",
          "description": "Amount of the exceptional entry"
        },
        "month": {
          "type": "string",
          "description": "Month of the exceptional entry"
        },
        "year": {
          "type": "number",
          "description": "Year of the exceptional entry"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["description", "amount", "month", "year", "createdAt"]
    }
  },
  "firestore": {
    "/members/{personalCode}": {
      "schema": {
        "$ref": "#/entities/Member"
      },
      "description": "Members collection where the document ID is the personal access code"
    },
    "/expenses/{expenseId}": {
      "schema": {
        "$ref": "#/entities/Expense"
      },
      "description": "Expenses collection"
    },
    "/revenues/{revenueId}": {
      "schema": {
        "$ref": "#/entities/Revenue"
      },
      "description": "Exceptional revenues collection"
    }
  }
}
